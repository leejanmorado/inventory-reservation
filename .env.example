# Local dev — run `supabase start` or `supabase status` and copy the secret key
# listed under Authentication keys (starts with sb_secret_)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-local-secret-key

# Cloud — values from Supabase dashboard → Settings → API → Secret key (sb_secret_...)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-cloud-secret-key

PORT=3000
